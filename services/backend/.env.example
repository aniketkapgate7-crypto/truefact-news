APP_NAME=TrueFact News API
APP_ENV=development
DEBUG=true

# Use this during local development
DATABASE_URL=sqlite:///./truefact_news.db

# PostgreSQL example for later:
# DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/truefact_news

# Google Fact Check Claim Search API
# Keep the real key only in your local .env file.
GOOGLE_FACT_CHECK_API_KEY=
GOOGLE_FACT_CHECK_BASE_URL=https://factchecktools.googleapis.com/v1alpha1/claims:search
GOOGLE_FACT_CHECK_TIMEOUT_SECONDS=10
GOOGLE_FACT_CHECK_LANGUAGE_CODE=en
